# macOS
.DS_Store

# Python bytecode generated by pytest / py_compile when the Python
# scripts under cli/gh-teacher/skeleton/dotgithub/scripts/ are run
# locally. The directories start with `__` and Go's `//go:embed`
# skips them by default, but keep them out of the index for
# everyone's local clones.
__pycache__/
*.pyc

# pytest's cache lives at the repo root when `pytest` is invoked
# from there.
.pytest_cache/

# Stray root-level node_modules / Vite cache created when npm or
# `npx vitest` is run from the repo root instead of inside web/.
# The real web dependencies live in web/node_modules (ignored by
# web/.gitignore). Nothing at the repo root needs node_modules.
/node_modules/

# Internal planning docs — kept out of git entirely so drafts never
# end up in the public mirror or shared review surface.
plans/
.tooling/
