{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/foundation50/classroom50/main/schemas/assignments-v1.schema.json",
  "title": "classroom50/assignments/v1",
  "description": "Machine-readable schema for <classroom>/assignments.json, mirroring the authoritative Go validators in cli/gh-teacher (assignments_json.go, tests.go, runtime.go). Intended for non-CLI clients (e.g. the GUI) to validate before writing. Two rules JSON Schema cannot express: (1) test names must be UNIQUE within an assignment, and (2) name length is capped at 100 BYTES (UTF-8), not characters — enforce both client-side. One normalization the CLI's parser applies that this schema rejects: a missing or empty `autograder` (normalized to \"default\") — clients should always write the normalized form, as the CLI does.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "assignments"],
  "properties": {
    "schema": { "const": "classroom50/assignments/v1" },
    "assignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/assignment" }
    }
  },
  "$defs": {
    "shortName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,38}$"
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "template", "mode", "autograder"],
      "properties": {
        "slug": { "$ref": "#/$defs/shortName" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "template": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "repo", "branch"],
          "properties": {
            "owner": { "type": "string", "minLength": 1 },
            "repo": { "type": "string", "minLength": 1 },
            "branch": { "type": "string", "minLength": 1 }
          }
        },
        "due": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}T([01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d(\\.\\d+)?(Z|[+-]([01]\\d|2[0-3]):[0-5]\\d)$",
          "description": "RFC 3339 timestamp. The CLI normalizes the teacher's input to a UTC instant (e.g. 2026-09-16T03:59:00Z) and records the original value/zone in `due_meta`; clients should write UTC too. The pattern still permits any offset so older files validate. Advisory: collect-scores compares it against each submission's datetime and marks rows `late` in scores.json; nothing enforces the deadline."
        },
        "due_meta": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input", "offset", "source"],
          "properties": {
            "input": {
              "type": "string",
              "description": "The due value as supplied (--due flag or migrated source deadline), whitespace-trimmed but otherwise verbatim, before UTC normalization."
            },
            "zone": {
              "type": "string",
              "description": "Best-effort IANA/local zone name; present only when the offset was auto-detected (an explicit offset carries no zone name)."
            },
            "offset": {
              "type": "string",
              "pattern": "^[+-]([01]\\d|2[0-3]):[0-5]\\d$",
              "description": "Zone offset applied at normalization, e.g. -04:00 (UTC is +00:00)."
            },
            "source": {
              "enum": ["explicit-offset", "auto-detected", "migrated"],
              "description": "How the offset was determined: from the input itself, auto-detected from the machine's local zone, or carried in from a migrated deadline."
            }
          },
          "description": "Write-side provenance for `due`, for auditing a wrong-zone deadline. Advisory metadata only -- collect-scores reads `due`, never this."
        },
        "mode": {
          "enum": ["individual", "group"],
          "description": "`individual` = one repo per student. `group` = a shared repo teammates join (the first accepter creates it; others run `gh student group join`), bounded by `max_group_size`. Group mode REQUIRES `max_group_size` (>= 2); individual mode must omit it. See the conditional at the assignment level."
        },
        "autograder": {
          "$ref": "#/$defs/shortName",
          "description": "Workflow-shim name; `default` for the universal shim. NOT the grading logic — that's autograder.py or `tests`."
        },
        "max_group_size": {
          "type": "integer",
          "minimum": 2,
          "maximum": 100,
          "description": "Maximum collaborators on a group repo. REQUIRED for `mode: group` (>= 2); MUST be omitted for `mode: individual`. Enforced within the CLI at join time — direct GitHub-UI invites can exceed it (documented limitation)."
        },
        "runtime": { "$ref": "#/$defs/runtime" },
        "tests": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/test" },
          "description": "Declarative tests. Mutually exclusive with a per-assignment autograder.py at <classroom>/autograders/<slug>/ — probe before writing."
        },
        "migrated_from": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "classroom_id", "assignment_id", "migrated_at"],
          "properties": {
            "source": { "type": "string" },
            "classroom_id": { "type": "integer" },
            "assignment_id": { "type": "integer" },
            "original_slug": { "type": "string" },
            "starter_repo": { "type": "string" },
            "invite_link": { "type": "string" },
            "migrated_at": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "group" } } },
          "then": { "required": ["max_group_size"] },
          "else": { "not": { "required": ["max_group_size"] } }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "description": "Omit entirely for the defaults (ubuntu-latest + Python 3.12). Never write empty-string fields.",
      "properties": {
        "runs-on": {
          "enum": [
            "ubuntu-latest", "ubuntu-24.04", "ubuntu-22.04", "ubuntu-20.04",
            "macos-latest", "macos-14", "macos-13",
            "windows-latest", "windows-2022", "windows-2019"
          ]
        },
        "container": {
          "type": "object",
          "additionalProperties": false,
          "required": ["image"],
          "properties": {
            "image": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]{0,255}$"
            },
            "user": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]{0,31}(:[A-Za-z0-9_][A-Za-z0-9_.-]{0,31})?$"
            },
            "credentials": {
              "type": "object",
              "additionalProperties": false,
              "required": ["username", "password"],
              "properties": {
                "username": { "type": "string", "minLength": 1 },
                "password": {
                  "type": "string",
                  "pattern": "^\\$\\{\\{\\s*secrets\\.[A-Za-z_][A-Za-z0-9_]*\\s*\\}\\}$",
                  "description": "Must be a ${{ secrets.NAME }} reference, never a raw token."
                }
              }
            }
          }
        },
        "python": { "$ref": "#/$defs/langVersion" },
        "node": { "$ref": "#/$defs/langVersion" },
        "java": { "$ref": "#/$defs/langVersion" },
        "go": { "$ref": "#/$defs/langVersion" },
        "apt": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.+-]{0,63}$" }
        }
      },
      "allOf": [
        {
          "if": { "required": ["container"] },
          "then": {
            "not": { "required": ["apt"] },
            "properties": {
              "runs-on": {
                "enum": ["ubuntu-latest", "ubuntu-24.04", "ubuntu-22.04", "ubuntu-20.04"],
                "description": "GitHub Actions runs containers on Ubuntu hosts only."
              }
            }
          }
        }
      ]
    },
    "langVersion": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._+-]{1,32}$"
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "run"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[^\\u0000-\\u001f\\u007f]+$",
          "description": "Unique within the assignment (enforce client-side); <= 100 UTF-8 bytes; no control characters."
        },
        "type": { "enum": ["io", "run", "python"] },
        "setup": { "type": "string" },
        "run": { "type": "string", "minLength": 1 },
        "input": { "type": "string" },
        "input-file": { "type": "string" },
        "expected": { "type": "string" },
        "expected-file": { "type": "string" },
        "comparison": { "enum": ["included", "exact", "regex"] },
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "maximum": 600,
          "description": "Seconds, 1-600. 0 (or omitted) means the default of 10s."
        },
        "exit-code": { "type": "integer", "minimum": 0, "maximum": 255 },
        "points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000,
          "description": "Defaults to 0 (informational test) when omitted; the CLI always writes it."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "io" } } },
          "then": {
            "required": ["comparison"],
            "not": { "required": ["exit-code"] }
          },
          "else": {
            "allOf": [
              { "not": { "required": ["input"] } },
              { "not": { "required": ["input-file"] } },
              { "not": { "required": ["expected"] } },
              { "not": { "required": ["expected-file"] } },
              { "not": { "required": ["comparison"] } }
            ]
          }
        },
        {
          "if": { "properties": { "type": { "const": "python" } } },
          "then": { "not": { "required": ["exit-code"] } }
        },
        { "not": { "required": ["input", "input-file"] } },
        { "not": { "required": ["expected", "expected-file"] } },
        {
          "if": {
            "properties": {
              "type": { "const": "io" },
              "comparison": { "enum": ["included", "regex"] }
            }
          },
          "then": {
            "anyOf": [
              { "required": ["expected"], "properties": { "expected": { "minLength": 1 } } },
              { "required": ["expected-file"], "properties": { "expected-file": { "minLength": 1 } } }
            ]
          }
        }
      ]
    }
  }
}
